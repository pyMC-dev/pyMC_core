# CH341 USB-to-SPI adapter
# VID=0x1A86, PID=0x5512
# Grant access to plugdev group and set world-readable/writable
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="5512", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb_device", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="5512", MODE="0666", GROUP="plugdev", TAG+="uaccess"
